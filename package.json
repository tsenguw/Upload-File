{
  "name": "myn8n",
  "version": "1.0.0",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },


  "build": {
    "appId": "com.company.myn8n",

    "productName": "MyN8N",

    "extraResources": [
      {
        "from": "runtime",
        "to": "runtime"
      },
      {
        "from": "node_modules",
        "to": "node_modules"
      }
    ],

    "win": {
      "target": [
        "nsis"
      ]
    },

    "files": [
      "main.js",
      "package.json",
      "runtime/**/*",
      "node_modules/**/*",
      "data/**/*"
    ]
  },

  "devDependencies": {
    "electron": "^latest",
    "electron-builder": "^latest"
  }
}